fn add(a: i32, b: i32) -> i32 {
    a + b
}

fn square(x: f32) -> f32 {
    x * x
}

fn borrow<'a>(s: &'a str) -> &'a str {
    s
}

fn pick_first<'a>(a: &'a str, b: &'a str) -> &'a str {
    a
}

fn use_static(s: &'static str) -> &'static str {
    s
}

struct Point {
    x: i32,
    y: i32,
}

struct Borrowed<'a> {
    name: &'a str,
}

enum Color {
    Red,
    Green,
    Blue,
}

union Value {
    i: i32,
    f: f32,
}

trait Draw {
    fn draw(&self);
}

trait AsStr<'a> {
    fn as_str(&'a self) -> &'a str;
}

impl Point {
    fn new(x: i32, y: i32) -> Self {
        Self { x, y }
    }

    fn sum(&self) -> i32 {
        self.x + self.y
    }
}

impl<'a> Borrowed<'a> {
    fn new(name: &'a str) -> Self {
        Self { name }
    }
}

fn main() {
    let p = Point::new(1, 2);
    let arr = [1, 2, 3];

    if true {
        println!("hello");
    } else {
        println!("nope");
    }

    for i in 0..10 {
        println!("{}", i);
    }

    let value = Some(1);
    let result = match value {
        Some(v) => v,
        None => 0,
    };

    let text: &'static str = "hello";
    let borrowed = borrow(text);
    let holder = Borrowed::new(borrowed);

    println!("{}", result);
    println!("{}", holder.name);
}

macro_rules! my_macro {
    ($name:ident) => {
        println!("{}", $name);
    };
}

